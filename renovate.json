{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "apps/renovate/**"
      ],
      "groupName": "renovate",
      "extends": [
        ":semanticCommitScope(renovate)"
      ],
      "addLabels": [
        "renovate"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": false
    },
    {
      "matchFileNames": [
        "apps/code-server/**"
      ],
      "groupName": "code-server",
      "extends": [
        ":semanticCommitScope(code-server)"
      ],
      "addLabels": [
        "code-server"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": false
    },
    {
      "matchFileNames": [
        "apps/stash/**"
      ],
      "groupName": "stash",
      "extends": [
        ":semanticCommitScope(stash)"
      ],
      "addLabels": [
        "stash"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": false
    },
    {
      "matchFileNames": [
        "apps/gluetun-rutorrent-portforward/**"
      ],
      "groupName": "gluetun-rutorrent-portforward",
      "extends": [
        ":semanticCommitScope(gluetun-rutorrent-portforward)"
      ],
      "addLabels": [
        "portforward"
      ],
      "automerge": true,
      "automergeType": "branch",
      "platformAutomerge": false
    }
  ]
}
